# ============================================================
# CDSP Game — Variables de Entorno
# ============================================================
# Copia este archivo como .env y ajusta los valores a tu entorno.

# ── Servidor de Juego ────────────────────────────────────────
# Puerto donde escucha el servidor CDSP (TCP)
SERVER_PORT=8080

# Archivo de logs del servidor de juego
SERVER_LOG_FILE=logs.txt

# ── Servidor DNS ─────────────────────────────────────────────
# Puerto donde escucha el mini-servidor DNS (UDP)
DNS_PORT=5353

# IP del servidor DNS (usado por el cliente para enviar QUERY/REGISTER)
DNS_SERVER=127.0.0.1


